# =============================================================================
# Environment Variables
# Copy this file to .env and fill in the values for your environment.
# =============================================================================

# -----------------------------------------------------------------------------
# Session (REQUIRED)
# -----------------------------------------------------------------------------
# Used by nuxt-auth-utils to encrypt session cookies.
# Must be at least 32 characters. Generate one with: openssl rand -base64 32
NUXT_SESSION_PASSWORD=

# -----------------------------------------------------------------------------
# Directus CMS (REQUIRED)
# -----------------------------------------------------------------------------
DIRECTUS_URL=https://admin.huestudios.company
DIRECTUS_STATIC_TOKEN=
DIRECTUS_SERVER_TOKEN=
DIRECTUS_WEBSOCKET_URL=wss://admin.huestudios.company/websocket

# -----------------------------------------------------------------------------
# Stripe Payments
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_SECRET_KEY_TEST=
STRIPE_PUBLIC_KEY=
STRIPE_PUBLIC_KEY_TEST=
STRIPE_WEBHOOK_SECRET=

# Stripe Subscription Price IDs (from your Stripe Dashboard > Products)
STRIPE_PRICE_SOLO=
STRIPE_PRICE_SOLO_ANNUAL=
STRIPE_PRICE_STUDIO=
STRIPE_PRICE_STUDIO_ANNUAL=
STRIPE_PRICE_AGENCY=
STRIPE_PRICE_AGENCY_ANNUAL=

# Token & Scan Credit Package Price IDs
STRIPE_PRICE_TOKENS_100K=
STRIPE_PRICE_TOKENS_500K=
STRIPE_PRICE_TOKENS_1_5M=
STRIPE_PRICE_SCANS_100=
STRIPE_PRICE_SCANS_500=

# Add-On Subscription Price IDs
STRIPE_PRICE_ADDON_SEATS_5=
STRIPE_PRICE_ADDON_COMMS=
STRIPE_PRICE_ADDON_CLIENT_STARTER=
STRIPE_PRICE_ADDON_CLIENT_PRO=
STRIPE_PRICE_ADDON_CLIENT_UNLIMITED=
STRIPE_PRICE_ADDON_WHITE_LABEL=

# -----------------------------------------------------------------------------
# AI / LLM (Anthropic Claude)
# -----------------------------------------------------------------------------
NUXT_LLM_API_KEY=

# -----------------------------------------------------------------------------
# SendGrid Email
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=hello@huestudios.company
SENDGRID_FROM_NAME=Hue Creative Agency
SENDGRID_BCC_EMAIL=
SENDGRID_REPLY_TO_EMAIL=

# -----------------------------------------------------------------------------
# Daily.co (Video Conferencing)
# -----------------------------------------------------------------------------
DAILY_API_KEY=

# -----------------------------------------------------------------------------
# Twilio — Master Account (Voice / SMS)
# Used to provision per-org sub-accounts. Individual org credentials are
# stored in organizations.twilio_subaccount_sid/token, not here.
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_API_KEY=
TWILIO_API_SECRET=

# -----------------------------------------------------------------------------
# Google OAuth (Calendar + SSO Sign-In)
# Same credentials are used for both Google Calendar sync and "Sign in with Google".
# SSO is configured on the Directus server — see docs/directus-sso-setup.md
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Azure / Outlook OAuth & Calendar
# Same credentials are used for Outlook Calendar sync.
# For "Sign in with Microsoft" SSO, configure on the Directus server.
# -----------------------------------------------------------------------------
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Apple Sign-In (SSO only — no Apple Calendar integration)
# Apple SSO is configured on the Directus server, not here.
# See docs/directus-sso-setup.md for Apple Developer Portal setup.
# -----------------------------------------------------------------------------
# No Nuxt-side env vars needed — Apple auth is handled entirely by Directus.

# -----------------------------------------------------------------------------
# Social Media - Instagram
# -----------------------------------------------------------------------------
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=

# -----------------------------------------------------------------------------
# Social Media - TikTok
# -----------------------------------------------------------------------------
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=

# -----------------------------------------------------------------------------
# Social Media - LinkedIn
# -----------------------------------------------------------------------------
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=

# -----------------------------------------------------------------------------
# Social Media - Facebook Pages
# (Same Meta app as Instagram — APP_ID/APP_SECRET fall back to Instagram if blank)
# -----------------------------------------------------------------------------
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=

# -----------------------------------------------------------------------------
# Social Media - Threads
# (Same Meta app as Instagram — APP_ID/APP_SECRET fall back to Instagram if blank)
# -----------------------------------------------------------------------------
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_REDIRECT_URI=

# -----------------------------------------------------------------------------
# Social Media - Encryption
# -----------------------------------------------------------------------------
SOCIAL_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Cron Jobs
# -----------------------------------------------------------------------------
CRON_SECRET=

# -----------------------------------------------------------------------------
# Public / Client-side
# -----------------------------------------------------------------------------
SITE_URL=https://huestudios.company
APP_URL=https://huestudios.company
COMPANY_NAME=

# Directus Roles (UUIDs from your Directus instance)
NUXT_PUBLIC_ADMIN_ROLE_ID=3a63a4e1-c82e-46f8-9993-7f11ac6a4b01
NUXT_PUBLIC_CLIENT_MANAGER_ROLE_ID=7b62b285-e3a8-46ff-9e8c-d1445a3c13bb
NUXT_PUBLIC_DIRECTUS_ROLE_USER=
NUXT_PUBLIC_DEFAULT_TEAM_ID=org-default
