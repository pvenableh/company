# =============================================================================
# Environment Variables
# Copy this file to .env and fill in the values for your environment.
# =============================================================================

# -----------------------------------------------------------------------------
# Session (REQUIRED)
# -----------------------------------------------------------------------------
# Used by nuxt-auth-utils to encrypt session cookies.
# Must be at least 32 characters. Generate one with: openssl rand -base64 32
NUXT_SESSION_PASSWORD=

# -----------------------------------------------------------------------------
# Directus CMS (REQUIRED)
# -----------------------------------------------------------------------------
DIRECTUS_URL=https://admin.earnest.guru
DIRECTUS_SERVER_TOKEN=
DIRECTUS_WEBSOCKET_URL=wss://admin.earnest.guru/websocket

# -----------------------------------------------------------------------------
# Stripe Payments
# -----------------------------------------------------------------------------
# Key selection is driven by NODE_ENV (server/utils/stripe.ts:11-14):
#   production → STRIPE_SECRET_KEY (live)  +  STRIPE_PUBLIC_KEY (live)
#   other      → STRIPE_SECRET_KEY_TEST    +  STRIPE_PUBLIC_KEY_TEST
# STRIPE_WEBHOOK_SECRET is a single slot — it must match whichever Stripe
# endpoint is firing events into this deployment (live endpoint → live signing
# secret; Stripe CLI `stripe listen` → its generated whsec_...). There is no
# separate *_TEST slot for the webhook secret.
STRIPE_SECRET_KEY=
STRIPE_SECRET_KEY_TEST=
STRIPE_PUBLIC_KEY=
STRIPE_PUBLIC_KEY_TEST=
STRIPE_WEBHOOK_SECRET=

# Subscription Price IDs — from Stripe Dashboard > Products (live mode for prod)
# Each env var maps to a canonical `organizations.plan` slug via planFromPriceId()
# in server/utils/stripe.ts. Stored slugs: free | solo | studio | agency | enterprise
# (free = no active sub, enterprise = hand-configured).
STRIPE_PRICE_SOLO=            # → plan: 'solo'   ($49/mo,  100K tokens, 25 scans)
STRIPE_PRICE_SOLO_ANNUAL=     # → plan: 'solo'   ($408/yr)
STRIPE_PRICE_STUDIO=          # → plan: 'studio' ($149/mo, 400K tokens, 150 scans)
STRIPE_PRICE_STUDIO_ANNUAL=   # → plan: 'studio' ($1,241/yr)
STRIPE_PRICE_AGENCY=          # → plan: 'agency' ($299/mo, 1M tokens, 500 scans)
STRIPE_PRICE_AGENCY_ANNUAL=   # → plan: 'agency' ($2,491/yr)

# Token Refill Package Price IDs — CURRENTLY DORMANT.
# server/api/stripe/tokens/checkout.post.ts uses inline `price_data` (not a
# pre-created Stripe Price), so these env vars are read by nothing at runtime.
# Leave blank unless/until tokens checkout is refactored to reference Prices.
STRIPE_PRICE_TOKENS_100K=
STRIPE_PRICE_TOKENS_500K=
STRIPE_PRICE_TOKENS_1_5M=

# Scan Credit Package Price IDs — CURRENTLY DORMANT.
# SCAN_PACKAGES is defined in server/utils/stripe.ts but no consumer endpoint
# exists yet. Safe to leave blank.
STRIPE_PRICE_SCANS_100=
STRIPE_PRICE_SCANS_500=

# Add-On Subscription Price IDs — read by server/api/stripe/addons/subscribe.post.ts
# (and detected on incoming subscriptions by addonFromPriceId). No UI caller
# yet — setting these enables server-side add-on provisioning, leaving them
# blank returns a 500 from /api/stripe/addons/subscribe. Addons do NOT gate any
# UI surface today, so blank = feature disabled, not broken.
STRIPE_PRICE_ADDON_SEATS_5=
STRIPE_PRICE_ADDON_COMMS=
STRIPE_PRICE_ADDON_CLIENT_STARTER=
STRIPE_PRICE_ADDON_CLIENT_PRO=
STRIPE_PRICE_ADDON_CLIENT_UNLIMITED=
STRIPE_PRICE_ADDON_WHITE_LABEL=

# -----------------------------------------------------------------------------
# Demo Mode (Public Try-It Workspaces)
# -----------------------------------------------------------------------------
# Two shared demo workspaces seeded via:
#   pnpm tsx scripts/setup-demo-org.ts           (Solo — Member role)
#   pnpm tsx scripts/setup-demo-agency-org.ts    (Agency — Admin role)
# The login endpoints (/api/auth/demo-login and /api/auth/demo-agency-login)
# read the _PASSWORD values at request time — rotating either means re-running
# the matching setup script with the new env value.
# Emails default to demo@earnest.guru / demo-agency@earnest.guru when blank.
DEMO_USER_EMAIL=
DEMO_USER_PASSWORD=
DEMO_AGENCY_USER_EMAIL=
DEMO_AGENCY_USER_PASSWORD=

# -----------------------------------------------------------------------------
# AI / LLM (Anthropic Claude)
# -----------------------------------------------------------------------------
NUXT_LLM_API_KEY=

# -----------------------------------------------------------------------------
# SendGrid Email
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=hello@earnest.guru
SENDGRID_FROM_NAME=Earnest
SENDGRID_BCC_EMAIL=
SENDGRID_REPLY_TO_EMAIL=hello@earnest.guru

# -----------------------------------------------------------------------------
# Daily.co (Video Conferencing)
# -----------------------------------------------------------------------------
DAILY_API_KEY=

# -----------------------------------------------------------------------------
# Twilio — Master Account (Voice / SMS)
# Used to provision per-org sub-accounts. Individual org credentials are
# stored in organizations.twilio_subaccount_sid/token, not here.
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_API_KEY=
TWILIO_API_SECRET=

# -----------------------------------------------------------------------------
# Google OAuth (Calendar + SSO Sign-In)
# Same credentials are used for both Google Calendar sync and "Sign in with Google".
# SSO is configured on the Directus server — see docs/directus-sso-setup.md
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Azure / Outlook OAuth & Calendar
# Same credentials are used for Outlook Calendar sync.
# For "Sign in with Microsoft" SSO, configure on the Directus server.
# -----------------------------------------------------------------------------
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Apple Sign-In (SSO only — no Apple Calendar integration)
# Apple SSO is configured on the Directus server, not here.
# See docs/directus-sso-setup.md for Apple Developer Portal setup.
# -----------------------------------------------------------------------------
# No Nuxt-side env vars needed — Apple auth is handled entirely by Directus.

# -----------------------------------------------------------------------------
# Social Media - Instagram
# -----------------------------------------------------------------------------
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=

# -----------------------------------------------------------------------------
# Social Media - TikTok
# -----------------------------------------------------------------------------
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=

# -----------------------------------------------------------------------------
# Social Media - LinkedIn
# -----------------------------------------------------------------------------
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=

# -----------------------------------------------------------------------------
# Social Media - Facebook Pages
# (Same Meta app as Instagram — APP_ID/APP_SECRET fall back to Instagram if blank)
# -----------------------------------------------------------------------------
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=

# -----------------------------------------------------------------------------
# Social Media - Threads
# (Same Meta app as Instagram — APP_ID/APP_SECRET fall back to Instagram if blank)
# -----------------------------------------------------------------------------
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_REDIRECT_URI=

# -----------------------------------------------------------------------------
# Social Media - Encryption
# -----------------------------------------------------------------------------
SOCIAL_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Redis Queue (BullMQ — for async AI jobs)
# Points to the 'queue' Redis container on the Docker network
# -----------------------------------------------------------------------------
REDIS_QUEUE_URL=redis://queue:6379

# -----------------------------------------------------------------------------
# Cron Jobs
# -----------------------------------------------------------------------------
CRON_SECRET=

# -----------------------------------------------------------------------------
# Public / Client-side
# -----------------------------------------------------------------------------
SITE_URL=https://app.earnest.guru
APP_URL=https://app.earnest.guru
COMPANY_NAME=

# Directus Roles (UUIDs from your Directus instance)
NUXT_PUBLIC_ADMIN_ROLE_ID=3a63a4e1-c82e-46f8-9993-7f11ac6a4b01
NUXT_PUBLIC_CLIENT_MANAGER_ROLE_ID=7b62b285-e3a8-46ff-9e8c-d1445a3c13bb
NUXT_PUBLIC_DIRECTUS_ROLE_USER=
NUXT_PUBLIC_DEFAULT_TEAM_ID=org-default
